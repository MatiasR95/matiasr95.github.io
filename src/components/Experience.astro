---
import { experience } from '../data/site';
---

<section id="experience" class="section bg-paper">
  <div class="container-page">
    <div class="mb-12 max-w-2xl" data-reveal>
      <p class="eyebrow">Experience</p>
      <span class="rule-gold mt-4"></span>
      <h2 class="mt-6 font-display text-3xl font-extrabold text-ink sm:text-4xl">Where I’ve done the work.</h2>
    </div>

    <div class="relative border-l border-line pl-8 sm:pl-10">
      {
        experience.map((job) => (
          <div class="relative pb-12 last:pb-0" data-reveal>
            <span class="absolute -left-[41px] top-1.5 flex h-4 w-4 items-center justify-center sm:-left-[49px]">
              <span class="h-3 w-3 rounded-full border-2 border-gold bg-white"></span>
            </span>
            <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1">
              <h3 class="font-display text-xl font-bold text-ink">
                {job.role} <span class="text-gold">· {job.company}</span>
              </h3>
              <p class="text-sm font-medium text-muted">{job.period}</p>
            </div>
            <p class="mt-0.5 text-sm text-muted">{job.place}</p>
            <p class="mt-3 max-w-3xl text-[15px] leading-relaxed text-ink/70">{job.body}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
