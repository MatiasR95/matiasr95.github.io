---
import { Icon } from 'astro-icon/components';
import { projects } from '../data/site';
---

<section id="projects" class="section bg-paper">
  <div class="container-page">
    <div class="mb-12 max-w-2xl" data-reveal>
      <p class="eyebrow">Projects</p>
      <span class="rule-gold mt-4"></span>
      <h2 class="mt-6 font-display text-3xl font-extrabold text-ink sm:text-4xl">Selected work.</h2>
    </div>

    <div class="grid gap-6 md:grid-cols-2">
      {
        projects.map((p) => (
          <article
            class:list={[
              'card flex flex-col p-7 transition-transform duration-300 hover:-translate-y-1',
              p.featured && 'md:col-span-2 ring-1 ring-gold/30',
            ]}
            data-reveal
          >
            {p.featured && (
              <span class="mb-4 inline-flex w-fit items-center gap-1.5 rounded-full bg-gold/10 px-3 py-1 text-xs font-semibold text-gold">
                <Icon name="lucide:star" class="h-3.5 w-3.5" />
                Featured
              </span>
            )}
            <h3 class="font-display text-xl font-bold text-ink">{p.title}</h3>
            <p class="mt-3 flex-1 text-[15px] leading-relaxed text-ink/70">{p.result}</p>
            <ul class="mt-5 flex flex-wrap gap-2">
              {p.tools.map((t) => (
                <li class="rounded-md bg-ink/5 px-2.5 py-1 text-xs font-medium text-ink/60">{t}</li>
              ))}
            </ul>
          </article>
        ))
      }
    </div>
  </div>
</section>
