---
import { Icon } from 'astro-icon/components';
import { getCollection } from 'astro:content';

const all = await getCollection('projects');
const byOrder = (a, b) => a.data.order - b.data.order;
const groups = [
  { label: 'Professional', items: all.filter((p) => p.data.category === 'professional').sort(byOrder) },
  { label: 'Personal', items: all.filter((p) => p.data.category === 'personal').sort(byOrder) },
];
---

<section id="projects" class="section bg-paper">
  <div class="container-page">
    <div class="mb-10 max-w-2xl" data-reveal>
      <p class="eyebrow">Projects</p>
      <span class="rule-gold mt-4"></span>
      <h2 class="mt-6 font-display text-3xl font-extrabold text-ink sm:text-4xl">Selected work.</h2>
      <p class="mt-4 text-lg text-ink/70">
        Real case studies — the professional work, and the passion projects where I keep my data skills sharp.
      </p>
    </div>

    {
      groups.map((group) => (
        <div class="mt-14">
          <div class="mb-6 flex items-center gap-4" data-reveal>
            <h3 class="font-display text-xl font-bold text-ink">{group.label}</h3>
            <span class="text-sm font-medium text-muted">{group.items.length}</span>
            <span class="h-px flex-1 bg-line" />
          </div>

          <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {group.items.map((p) => (
              <a
                href={`/projects/${p.id}`}
                class:list={[
                  'card group flex flex-col overflow-hidden transition-transform duration-300 hover:-translate-y-1',
                  p.data.featured && 'ring-1 ring-gold/40',
                ]}
                data-reveal
              >
                {p.data.cover ? (
                  <div class="aspect-[16/10] overflow-hidden bg-paper">
                    <img
                      src={p.data.cover}
                      alt={p.data.title}
                      loading="lazy"
                      class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-[1.03]"
                    />
                  </div>
                ) : (
                  <div class="flex aspect-[16/10] items-center justify-center bg-gradient-to-br from-ink to-night">
                    <Icon name="lucide:sparkles" class="h-10 w-10 text-gold-bright" />
                  </div>
                )}

                <div class="flex flex-1 flex-col p-6">
                  {p.data.featured && (
                    <span class="mb-3 inline-flex w-fit items-center gap-1.5 rounded-full bg-gold/10 px-3 py-1 text-xs font-semibold text-gold">
                      <Icon name="lucide:star" class="h-3.5 w-3.5" />
                      Featured
                    </span>
                  )}
                  <h4 class="font-display text-lg font-bold leading-snug text-ink group-hover:text-gold">
                    {p.data.title}
                  </h4>
                  <p class="mt-2 flex-1 text-sm leading-relaxed text-ink/65 line-clamp-3">{p.data.summary}</p>
                  <ul class="mt-4 flex flex-wrap gap-1.5">
                    {p.data.tools.slice(0, 4).map((t) => (
                      <li class="rounded-md bg-ink/5 px-2 py-0.5 text-xs font-medium text-ink/55">{t}</li>
                    ))}
                  </ul>
                  <span class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold text-gold">
                    View project
                    <Icon name="lucide:arrow-right" class="h-4 w-4 transition-transform group-hover:translate-x-1" />
                  </span>
                </div>
              </a>
            ))}
          </div>
        </div>
      ))
    }
  </div>
</section>
