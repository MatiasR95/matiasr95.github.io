---
import { Icon } from 'astro-icon/components';
import { getCollection } from 'astro:content';
import { site } from '../data/site';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric', timeZone: 'UTC' });
---

<section id="writing" class="section bg-paper">
  <div class="container-page">
    <div class="mb-12 flex flex-wrap items-end justify-between gap-4" data-reveal>
      <div class="max-w-2xl">
        <p class="eyebrow">Writing</p>
        <span class="rule-gold mt-4"></span>
        <h2 class="mt-6 font-display text-3xl font-extrabold text-ink sm:text-4xl">
          I write about data, BI &amp; AI.
        </h2>
        <p class="mt-4 text-lg text-ink/70">
          Practical lessons in English and Spanish — honest, useful, and a little fun.
        </p>
      </div>
      {posts.length > 0 && (
        <a href="/blog" class="btn-ghost shrink-0">
          All posts
          <Icon name="lucide:arrow-right" class="h-4 w-4" />
        </a>
      )}
    </div>

    {
      posts.length > 0 ? (
        <div class="grid gap-6 md:grid-cols-3">
          {posts.map((post) => (
            <a
              href={`/blog/${post.id}`}
              class="card group flex flex-col p-6 transition-transform duration-300 hover:-translate-y-1"
              data-reveal
            >
              <p class="text-xs font-medium text-muted">{fmt(post.data.date)}</p>
              <h3 class="mt-2 font-display text-lg font-bold leading-snug text-ink group-hover:text-gold">
                {post.data.title}
              </h3>
              <p class="mt-3 flex-1 text-sm leading-relaxed text-ink/65 line-clamp-4">{post.data.excerpt}</p>
              <span class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold text-gold">
                Read
                <Icon name="lucide:arrow-right" class="h-4 w-4 transition-transform group-hover:translate-x-1" />
              </span>
            </a>
          ))}
        </div>
      ) : (
        <div class="card p-8 text-center" data-reveal>
          <p class="text-lg text-ink/70">I share what I’m learning on LinkedIn.</p>
          <a href={site.socials.linkedin} target="_blank" rel="noopener" class="btn-primary mt-5">
            <Icon name="lucide:linkedin" class="h-4 w-4" />
            Read my latest on LinkedIn
          </a>
        </div>
      )
    }
  </div>
</section>
