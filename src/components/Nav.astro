---
import { Icon } from 'astro-icon/components';
import { nav, site } from '../data/site';
---

<header id="site-nav" class="fixed inset-x-0 top-0 z-50">
  <div class="container-page">
    <div
      class="mt-3 flex items-center justify-between rounded-full border border-transparent px-4 py-2.5 transition-all duration-300"
      data-nav-bar
    >
      <a href="/" class="group flex items-center gap-2 font-display text-base font-bold text-ink">
        <span class="inline-block h-2.5 w-2.5 rounded-full bg-gold transition-transform group-hover:scale-125"></span>
        Matías Rossi
      </a>

      <nav class="hidden items-center gap-7 md:flex">
        {
          nav.map((item) => (
            <a
              href={item.href}
              data-navlink={item.href.replace('/#', '')}
              class="text-sm font-medium text-ink/70 transition-colors hover:text-gold"
            >
              {item.label}
            </a>
          ))
        }
      </nav>

      <div class="flex items-center gap-2">
        <a
          href={site.socials.linkedin}
          target="_blank"
          rel="noopener"
          class="hidden btn-primary !px-5 !py-2 text-xs md:inline-flex"
        >
          Let’s connect
        </a>
        <button
          id="nav-toggle"
          aria-label="Open menu"
          aria-expanded="false"
          class="flex h-10 w-10 items-center justify-center rounded-full text-ink transition-colors hover:bg-paper md:hidden"
        >
          <Icon name="lucide:menu" class="h-6 w-6" data-icon-menu />
          <Icon name="lucide:x" class="hidden h-6 w-6" data-icon-close />
        </button>
      </div>
    </div>

    <!-- Mobile menu -->
    <div id="mobile-menu" class="hidden md:hidden">
      <nav class="mt-2 rounded-2xl border border-line bg-white/95 p-3 shadow-card backdrop-blur-md">
        {
          nav.map((item) => (
            <a
              href={item.href}
              data-mobile-link
              class="block rounded-xl px-4 py-3 text-sm font-medium text-ink/80 transition-colors hover:bg-paper hover:text-gold"
            >
              {item.label}
            </a>
          ))
        }
        <a href={site.socials.linkedin} target="_blank" rel="noopener" class="btn-primary mt-2 w-full">
          Let’s connect
        </a>
      </nav>
    </div>
  </div>
</header>

<script>
  // Frosted background once the page is scrolled.
  const bar = document.querySelector('[data-nav-bar]');
  const onScroll = () => {
    if (!bar) return;
    bar.classList.toggle('bg-white/85', window.scrollY > 24);
    bar.classList.toggle('backdrop-blur-md', window.scrollY > 24);
    bar.classList.toggle('border-line', window.scrollY > 24);
    bar.classList.toggle('shadow-sm', window.scrollY > 24);
  };
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });

  // Mobile menu toggle.
  const toggle = document.getElementById('nav-toggle');
  const menu = document.getElementById('mobile-menu');
  const iconMenu = document.querySelector('[data-icon-menu]');
  const iconClose = document.querySelector('[data-icon-close]');
  const setOpen = (open: boolean) => {
    menu?.classList.toggle('hidden', !open);
    toggle?.setAttribute('aria-expanded', String(open));
    toggle?.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
    iconMenu?.classList.toggle('hidden', open);
    iconClose?.classList.toggle('hidden', !open);
  };
  toggle?.addEventListener('click', () => setOpen(!!menu?.classList.contains('hidden')));
  menu?.querySelectorAll('[data-mobile-link]').forEach((l) =>
    l.addEventListener('click', () => setOpen(false))
  );

  // Scroll-spy: highlight the nav link for the section in view.
  const links = Array.from(document.querySelectorAll<HTMLAnchorElement>('[data-navlink]'));
  const sections = links
    .map((l) => document.getElementById(l.dataset.navlink || ''))
    .filter((s): s is HTMLElement => !!s);
  if (sections.length) {
    const spy = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (!e.isIntersecting) return;
          const id = (e.target as HTMLElement).id;
          links.forEach((l) => {
            const active = l.dataset.navlink === id;
            l.classList.toggle('text-gold', active);
            l.classList.toggle('text-ink/70', !active);
          });
        });
      },
      { rootMargin: '-45% 0px -50% 0px' }
    );
    sections.forEach((s) => spy.observe(s));
  }
</script>
