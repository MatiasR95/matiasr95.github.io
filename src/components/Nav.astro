---
import { nav, site } from '../data/site';
---

<header
  id="site-nav"
  class="fixed inset-x-0 top-0 z-50 transition-all duration-300"
  data-nav
>
  <div class="container-page">
    <div
      class="mt-3 flex items-center justify-between rounded-full border border-transparent px-4 py-2.5 transition-all duration-300"
      data-nav-bar
    >
      <a href="/" class="group flex items-center gap-2 font-display text-base font-bold text-ink">
        <span class="inline-block h-2.5 w-2.5 rounded-full bg-gold transition-transform group-hover:scale-125"></span>
        Matías Rossi
      </a>

      <nav class="hidden items-center gap-7 md:flex">
        {
          nav.map((item) => (
            <a href={item.href} class="text-sm font-medium text-ink/70 transition-colors hover:text-gold">
              {item.label}
            </a>
          ))
        }
      </nav>

      <a href={site.socials.linkedin} target="_blank" rel="noopener" class="btn-primary !px-5 !py-2 text-xs">
        Let’s connect
      </a>
    </div>
  </div>
</header>

<script>
  // Frosted background once the page is scrolled.
  const bar = document.querySelector('[data-nav-bar]');
  const onScroll = () => {
    if (!bar) return;
    if (window.scrollY > 24) {
      bar.classList.add('bg-white/85', 'backdrop-blur-md', 'border-line', 'shadow-sm');
    } else {
      bar.classList.remove('bg-white/85', 'backdrop-blur-md', 'border-line', 'shadow-sm');
    }
  };
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });
</script>
