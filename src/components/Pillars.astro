---
import { Icon } from 'astro-icon/components';
import { pillars } from '../data/site';
---

<section class="section bg-white">
  <div class="container-page">
    <div class="mb-12 max-w-2xl" data-reveal>
      <p class="eyebrow">What I do</p>
      <span class="rule-gold mt-4"></span>
      <h2 class="mt-6 font-display text-3xl font-extrabold text-ink sm:text-4xl">
        From raw sources to decisions teams trust.
      </h2>
    </div>

    <div class="grid gap-6 md:grid-cols-3">
      {
        pillars.map((p) => (
          <article class="card group p-7 transition-transform duration-300 hover:-translate-y-1" data-reveal>
            <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-gold/10 text-gold">
              <Icon name={p.icon} class="h-6 w-6" />
            </div>
            <h3 class="mt-5 font-display text-lg font-bold text-ink">{p.title}</h3>
            <p class="mt-2 text-[15px] leading-relaxed text-ink/65">{p.body}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
