---
import { skillGroups, coreToolkit } from '../data/site';
---

<section id="skills" class="section bg-white">
  <div class="container-page">
    <div class="mb-10 max-w-2xl" data-reveal>
      <p class="eyebrow">Skills &amp; tech stack</p>
      <span class="rule-gold mt-4"></span>
      <h2 class="mt-6 font-display text-3xl font-extrabold text-ink sm:text-4xl">The tools I reach for.</h2>
    </div>

    <!-- Core toolkit today -->
    <div class="mb-10 rounded-2xl border border-gold/30 bg-gold/[0.04] p-6 sm:p-7" data-reveal>
      <p class="text-xs font-semibold uppercase tracking-[0.16em] text-gold">Most-used today</p>
      <div class="mt-4 flex flex-wrap gap-3">
        {
          coreToolkit.map((t) => (
            <span class="rounded-full bg-ink px-5 py-2 text-sm font-semibold text-white">{t}</span>
          ))
        }
      </div>
    </div>

    <div class="grid gap-6 sm:grid-cols-2">
      {
        skillGroups.map((group) => (
          <div class="card p-7" data-reveal>
            <h3 class="font-display text-sm font-bold uppercase tracking-wide text-gold">{group.title}</h3>
            <ul class="mt-4 flex flex-wrap gap-2">
              {group.items.map((item) => (
                <li class="rounded-full border border-line bg-paper px-3.5 py-1.5 text-sm font-medium text-ink/75">
                  {item}
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </div>
</section>
