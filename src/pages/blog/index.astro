---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { site } from '../../data/site';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric', timeZone: 'UTC' });
---

<Base
  title={`Writing — ${site.name}`}
  description="Practical lessons on data, business intelligence, and AI — in English and Spanish."
>
  <Nav />
  <main class="bg-paper pt-32 pb-24 sm:pt-40">
    <div class="container-page">
      <header class="mb-14 max-w-2xl">
        <p class="eyebrow">Writing</p>
        <span class="rule-gold mt-4"></span>
        <h1 class="mt-6 font-display text-4xl font-extrabold text-ink sm:text-5xl">
          Data, BI &amp; AI — in plain language.
        </h1>
        <p class="mt-5 text-lg text-ink/70">
          Short, useful lessons from the warehouse and the gym. English first, Spanish recap below each.
        </p>
      </header>

      <div class="grid gap-6 sm:grid-cols-2">
        {
          posts.map((post) => (
            <a
              href={`/blog/${post.id}`}
              class="card group flex flex-col overflow-hidden transition-transform duration-300 hover:-translate-y-1"
            >
              {post.data.cover && (
                <div class="aspect-[16/10] overflow-hidden bg-paper">
                  <img
                    src={post.data.cover}
                    alt={post.data.title}
                    loading="lazy"
                    class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-[1.03]"
                  />
                </div>
              )}
              <div class="flex flex-1 flex-col p-7">
                <p class="text-xs font-medium text-muted">{fmt(post.data.date)}</p>
                <h2 class="mt-2 font-display text-xl font-bold leading-snug text-ink group-hover:text-gold">
                  {post.data.title}
                </h2>
                <p class="mt-3 flex-1 text-[15px] leading-relaxed text-ink/65">{post.data.excerpt}</p>
                {post.data.tags.length > 0 && (
                  <ul class="mt-5 flex flex-wrap gap-2">
                    {post.data.tags.slice(0, 4).map((t) => (
                      <li class="rounded-md bg-ink/5 px-2.5 py-1 text-xs font-medium text-ink/55">#{t}</li>
                    ))}
                  </ul>
                )}
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </main>
  <Footer />
</Base>
