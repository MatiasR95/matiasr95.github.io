---
import { getCollection, render } from 'astro:content';
import { Icon } from 'astro-icon/components';
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { site } from '../../data/site';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({ params: { slug: project.id }, props: { project } }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const d = project.data;
---

<Base title={`${d.title} — ${site.name}`} description={d.summary} ogImage={d.cover ?? '/og.png'}>
  <Nav />
  <main class="bg-white pt-32 pb-24 sm:pt-40">
    <article class="container-page max-w-[820px]">
      <a href="/#projects" class="inline-flex items-center gap-1.5 text-sm font-semibold text-muted transition-colors hover:text-gold">
        <Icon name="lucide:arrow-left" class="h-4 w-4" />
        All projects
      </a>

      <header class="mt-6">
        <span class="inline-flex items-center rounded-full bg-gold/10 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-gold">
          {d.category}
        </span>
        <h1 class="mt-4 font-display text-3xl font-extrabold leading-tight text-ink sm:text-4xl">
          {d.title}
        </h1>
        <ul class="mt-5 flex flex-wrap gap-2">
          {d.tools.map((t) => (
            <li class="rounded-md bg-ink/5 px-2.5 py-1 text-xs font-medium text-ink/60">{t}</li>
          ))}
        </ul>
      </header>

      {
        d.cover && (
          <div class="mt-8 overflow-hidden rounded-2xl border border-line">
            <img src={d.cover} alt={d.title} class="w-full" loading="eager" />
          </div>
        )
      }

      <div class="prose-post mt-8">
        <Content />
      </div>

      {
        d.links.length > 0 && (
          <footer class="mt-10 border-t border-line pt-8">
            <p class="text-xs font-semibold uppercase tracking-[0.16em] text-muted">Read more</p>
            <div class="mt-4 flex flex-wrap gap-3">
              {d.links.map((l) => (
                <a href={l.href} target="_blank" rel="noopener" class="btn-ghost">
                  {l.label}
                  <Icon name="lucide:external-link" class="h-4 w-4" />
                </a>
              ))}
            </div>
          </footer>
        )
      }
    </article>
  </main>
  <Footer />
</Base>

<style>
  .prose-post :global(p) {
    margin-block: 1rem;
    font-size: 1.0625rem;
    line-height: 1.75;
    color: rgba(17, 17, 17, 0.8);
  }
</style>
